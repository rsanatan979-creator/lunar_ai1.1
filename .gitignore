# =============================================================
# Lunar AI — Root .gitignore
# =============================================================

# Python virtual environments
venv/
.venv/
env/
.env/

# Python bytecode caches
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribution / build artifacts
*.egg-info/
dist/
build/
*.egg

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/

# =============================================================
# Node / Frontend
# =============================================================
node_modules/
lunar-ops-ai/node_modules/

# Vite / build outputs (committed selectively)
lunar-ops-ai/dist/

# =============================================================
# Generated pipeline outputs (large binary files)
# =============================================================
output/
output/*.png
output/*.jpg
uploads/

# NumPy cache files
*.npy
*.npz

# =============================================================
# OS & Editor
# =============================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/settings.json

# =============================================================
# Model weights — large binary files (not for VCS)
# Add back individual weights files if needed via git-lfs
# =============================================================
# weights/best.pt   ← already committed; keep tracked
# weights/last.pt   ← already committed; keep tracked

# =============================================================
# Log files
# =============================================================
*.log
*.log.*

# =============================================================
# Temporary test files
# =============================================================
runs/
